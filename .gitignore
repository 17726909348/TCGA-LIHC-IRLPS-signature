# ============================================================================
# .gitignore for TCGA-LIHC-IRLPS-signature
# ============================================================================

# ============================================================================
# R files
# ============================================================================
.Rproj.user
.Rhistory
.RData
.Ruserdata
.Rproj
*.Rproj
.Rapp.history
.RDataTmp
.Rds

# ============================================================================
# Data files (too large for GitHub, users should download themselves)
# ============================================================================
*.txt
*.csv
*.xlsx
*.xls
*.rda
*.RData
*.rds
*.feather
*.tsv
*.tab

# ============================================================================
# Output files (optional - comment out if you want to share results)
# ============================================================================
*.pdf
*.png
*.jpg
*.jpeg
*.tiff
*.bmp
*.svg
*.eps

# ============================================================================
# R package renv
# ============================================================================
renv/library/
renv/staging/
renv/local/
renv/python/
renv/sandbox/
renv/activate.R
renv/settings.json
renv/lock/

# ============================================================================
# RStudio
# ============================================================================
.Rproj.user/
.Rproj.user.backup/
.Rhistory
.Rapp.history
.RData
.Ruserdata
.Rbuildignore
.Renviron

# ============================================================================
# macOS
# ============================================================================
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*.icloud

# ============================================================================
# Windows
# ============================================================================
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msm
*.exe
*.dll

# ============================================================================
# Linux
# ============================================================================
*~
.directory
*.swp
*.swo
*.swn
*.swm

# ============================================================================
# Temporary files
# ============================================================================
*.tmp
*.temp
*.log
*.out
*.error
*.aux
*.bak

# ============================================================================
# Backup files
# ============================================================================
*.bak
*.backup
*.old
*.orig
*.rej

# ============================================================================
# IDE files
# ============================================================================
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# ============================================================================
# Compiled files
# ============================================================================
*.class
*.o
*.so
*.dll
*.exe
